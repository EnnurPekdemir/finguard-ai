<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Konsol Log Yapılandırması -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Dosya Log Yapılandırması (logs/finguard.log dosyasına yazar) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/finguard.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Günlük döndürme (rollover) planı -->
            <fileNamePattern>logs/archived/finguard.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- Log geçmişini 30 gün boyunca sakla -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- SentinelBank FinGuard Paket Seviyesi Ayarı -->
    <logger name="com.sentinelbank.finguard" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>

    <!-- Kök (Root) Log Ayarı -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
